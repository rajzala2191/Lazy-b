# ─── iCloud CalDAV ────────────────────────────────────────────────────────────
# Your Apple ID email
ICLOUD_USERNAME=your@icloud.com

# App-Specific Password (NOT your Apple ID password)
# Generate at: appleid.apple.com → Sign-In and Security → App-Specific Passwords
ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Your iCloud CalDAV URL
# Find it: iPhone Settings → [Your Name] → iCloud → Passwords & Accounts → your calendar account
# Format: https://caldav.icloud.com/[your-principal-id]/calendars/[calendar-name]/
ICLOUD_CALENDAR_URL=https://caldav.icloud.com/

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
